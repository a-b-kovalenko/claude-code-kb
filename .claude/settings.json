{
  "plansDirectory": ".workspace",
  "permissions": {
    "allow": [
      "Bash(markdownlint *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/md-lint.sh\""
          }
        ]
      }
    ]
  }
}